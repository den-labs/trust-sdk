{
  "name": "@denlabs/ayni-sdk",
  "version": "0.1.2",
  "description": "TypeScript SDK for Ayni Trust Oracle API (Avalanche) — query trust scores with API key or x402 micropayments",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "test:e2e": "vitest run __tests__/e2e.test.ts",
    "example:get-score": "pnpm build && node examples/get-score.mjs",
    "example:get-score:x402": "pnpm build && node examples/get-score-x402.mjs"
  },
  "keywords": [
    "erc-8004",
    "trust",
    "reputation",
    "agents",
    "x402",
    "ayni",
    "avalanche"
  ],
  "author": "DenLabs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/den-labs/trust-sdk.git",
    "directory": "packages/ayni-sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@denlabs/trust-client-core": "workspace:*"
  },
  "peerDependencies": {
    "viem": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "viem": "^2.21.0",
    "vitest": "^2.0.0"
  }
}
